# Better Auth — https://www.better-auth.com/docs/installation
# Required: at least 32 characters, high entropy (e.g. openssl rand -base64 32)
BETTER_AUTH_SECRET=

# Better Auth Infrastructure (dashboard / analytics) — https://www.better-auth.com/docs/infrastructure/getting-started
# When set, the dash() plugin is enabled on the server. Omit locally if you are not using Infra.
# BETTER_AUTH_API_KEY=

# Base URL of the app (must match the origin in the browser, including port).
# Production: use one canonical host (e.g. https://www.example.com) — apex vs www are different origins for CORS.
BETTER_AUTH_URL=http://localhost:3000

# Optional on Vercel when the app is same-origin: omit so the client uses the tab’s origin.
# If set, it must match the host users open (www vs non-www).
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Optional: comma-separated extra origins for CSRF / Origin checks (preview domains, etc.)
# BETTER_AUTH_TRUSTED_ORIGINS=https://your-preview.vercel.app

# Database (Neon / Postgres)
# DATABASE_URL=

# Email (Resend)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
